# 개인 PC 전용 설정 예시 — 이 파일을 application-local.yml 로 복사해서 사용
# application-local.yml 은 .gitignore 대상 (Git에 올라가지 않음)

# SeaweedFS를 이 PC에서 직접 실행 중이면 Filer는 localhost 로 override (같은 PC에서 192.168.1.128 접속 실패할 수 있음)
# seaweedfs:
#   filer:
#     endpoint: http://localhost:8888
#     bucket: emp_photo

# spring:
#   datasource:
#     url: jdbc:oracle:thin:@localhost:1521:XE
